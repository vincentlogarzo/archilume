{
  "name": "Archilume Development Container",

  // Build from our Dockerfile instead of pulling a pre-built image directly.
  // context: ".." means the build context is the repo root (so COPY pyproject.toml works).
  // dockerfile: path to the Dockerfile, relative to the devcontainer.json location.
  //
  // OPTION: To use a pre-built image from a registry instead (faster for team onboarding),
  // replace the "build" block with:
  //   "image": "ghcr.io/<your-org>/archilume-dev:latest"
  // and remove the "build" block entirely.
  "build": {
    "dockerfile": "Dockerfile",
    "context": ".."
  },

  // postCreateCommand runs AFTER the container is created, every time.
  // Since our Dockerfile already installs everything, we don't need setup.sh.
  // This is now just a lightweight verification step.
  "postCreateCommand": "sudo chown -R vscode:vscode /workspaces/archilume && uv sync --frozen && python --version && oconv 2>&1 | head -1 || echo 'Radiance ready'",

  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "ms-python.black-formatter",
        "google.geminicodeassist",
        "Anthropic.claude-code",
        "kisstkondoros.vscode-gutter-preview",
        "vscode-infra.image-viewer",
        "mcrespo.veriv",
        "ms-azuretools.vscode-docker",
        "analytic-signal.preview-tiff",
        "mechatroner.rainbow-csv",
        "GrapeCity.gc-excelviewer",
        "PKief.material-icon-theme"
      ],
      "settings": {
        "python.defaultInterpreterPath": "${containerWorkspaceFolder}/.venv/bin/python",
        "python.formatting.provider": "black",
        "workbench.iconTheme": "material-icon-theme",
        "editor.formatOnSave": true,
        "workbench.editorAssociations": {
          "*.apng": "imagePreview.previewEditor",
          "*.tiff": "tiff.preview",
          "*.tif": "tiff.preview"
        }
      }
    }
  },

  "remoteEnv": {
    "PATH": "${containerEnv:PATH}:/usr/local/radiance/bin:${containerEnv:HOME}/.local/bin:${containerEnv:HOME}/google-cloud-sdk/bin",
    "RAYPATH": "/usr/local/accelerad/lib:/usr/local/radiance/lib",
    "UV_LINK_MODE": "copy",
    "CLAUDE_API_KEY": "${localEnv:CLAUDE_API_KEY}",
    "TZ": "${localEnv:TZ}",
    // X11 display forwarding — routes GUI windows from the container back to
    // the Windows host via VcXsrv. Users must have VcXsrv running on Windows
    // with "Disable access control" checked before opening the container.
    // VcXsrv download: https://sourceforge.net/projects/vcxsrv/
    "DISPLAY": "${localEnv:DISPLAY}"
  },

  "mounts": [],

  "forwardPorts": [],

  "postAttachCommand": {
    "server": "echo 'Archilume development environment ready!'"
  }
}
