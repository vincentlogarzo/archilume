{
  "name": "Archilume Development Container",

  // Build from docker/Dockerfile's archilume-dev target. Context is the repo
  // root so COPY paths (pyproject.toml, .devcontainer/Radiance_*) resolve.
  //
  // To swap to a pre-built image (faster team onboarding), replace the "build"
  // block with:  "image": "ghcr.io/<your-org>/archilume-dev:latest"
  "build": {
    "dockerfile": "../docker/Dockerfile",
    "context": "..",
    "target": "archilume-dev"
  },

  "remoteUser": "vscode",

  // Rewrite the in-container `vscode` user's UID/GID to match the host user
  // before the session starts. Without this, the devcontainer writes files
  // into the bind-mounted workspace as UID 1001:0, which clashes with the
  // host WSL user (UID 1000) and produces EACCES on VS Code file operations.
  // VS Code Dev Containers only — has no effect on `docker compose up`.
  "updateRemoteUserUID": true,

  // Runs after container creation. Dockerfile already baked deps into
  // /opt/venv, so this only: (1) fixes bind-mount ownership (UIDs unknown at
  // build time), (2) installs the project itself editably now that the
  // workspace is mounted (--no-install-project was used in the image build).
  "postCreateCommand": "sudo chown -R vscode:root /workspaces/archilume && uv sync --frozen",

  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "ms-python.black-formatter",
        "google.geminicodeassist",
        "Anthropic.claude-code",
        "kisstkondoros.vscode-gutter-preview",
        "vscode-infra.image-viewer",
        "mcrespo.veriv",
        "ms-azuretools.vscode-docker",
        "analytic-signal.preview-tiff",
        "mechatroner.rainbow-csv",
        "GrapeCity.gc-excelviewer",
        "PKief.material-icon-theme"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/opt/venv/bin/python",
        "python.formatting.provider": "black",
        "workbench.iconTheme": "material-icon-theme",
        "editor.formatOnSave": true,
        "workbench.editorAssociations": {
          "*.apng": "imagePreview.previewEditor",
          "*.tiff": "tiff.preview",
          "*.tif": "tiff.preview"
        }
      }
    }
  },

  // PATH/RAYPATH are set in the Dockerfile ENV. Only overrides/host-supplied
  // values go here.
  "remoteEnv": {
    "CLAUDE_API_KEY": "${localEnv:CLAUDE_API_KEY}",
    "TZ": "${localEnv:TZ}",
    // X11 display forwarding — routes GUI windows from the container back to
    // the Windows host via VcXsrv. Users must have VcXsrv running on Windows
    // with "Disable access control" checked before opening the container.
    // VcXsrv download: https://sourceforge.net/projects/vcxsrv/
    "DISPLAY": "${localEnv:DISPLAY}"
  },

  "mounts": [],

  "forwardPorts": [],

  "postAttachCommand": {
    "server": "echo 'Archilume development environment ready!'"
  }
}
