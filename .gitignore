__pycache__/
*.egg-info/
.venv/

# Test artefacts
.coverage
tests/.coverage
htmlcov/
.pytest_cache/

# AI tool settings — .claude/ is tracked so settings travel with the repo
.states/
.env
.env.local
*.key

# Documentation
docs/radiance_scratchpad.md

# Reflex framework reference docs (pulled, not project code)
.claude/skills/reflex-docs/reference/

# All simulation project data lives here — never commit project files
projects/*
!projects/.gitkeep

# Local debug logs. Unified trace file lives at ~/.archilume/logs/ (user
# home, not repo). These rules cover any stray log files that may still
# exist in the working tree from pre-refactor runs.
*.log
*.log.1
archilume_app_debug.log
archilume_app_debug.log.*
debug_trace.json

# SSH configuration (contains private keys - keep these secret!)
.ssh/
!.ssh/config.template

# Local hint file written by docker/launch-archilume.ps1 when Docker Desktop
# lives outside the default install path. Personal to the host, not shipped.
docker/.docker-path.txt

# Build artifacts from docker/build-zip.ps1 — recreated on demand.
docker/dist/
